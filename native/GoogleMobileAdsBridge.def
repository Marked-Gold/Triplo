# cinterop definition for the Objective-C AdMob bridge (native/ios/TriploAds.h).
#
# Only the bridge header is exposed to Kotlin/Native - the GoogleMobileAds SDK itself is never
# seen by cinterop (TriploAds.h imports only Foundation). The bridge implementation
# (TriploAds.m) is compiled and linked by Xcode in the generated iOS app target.
language = Objective-C
package = triploads
headers = TriploAds.h
headerFilter = TriploAds.h
